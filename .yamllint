---
extends: default
ignore: |
  argocd/charts/*/templates/
  argocd/charts/*/.argocd-source-*.yaml
rules:
  line-length:
    max: 120
    level: warning
  indentation:
    spaces: 2
  truthy:
    allowed-values: ['true', 'false', 'on']
  document-start:
    level: warning
  trailing-spaces:
    level: error
  empty-lines:
    level: warning
